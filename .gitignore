# --- AI assistant instructions (local only) ---
.github/copilot-instructions.md
**/CLAUDE.md
.cursorrules
.agent/
test.md

# Ignore key files for decrypting credentials and more.
/config/*.key

# Rails
/log/*
/tmp/*
/storage/*
!/log/.keep
!/tmp/.keep
!/storage/.keep

# Bundler
/.bundle/
/vendor/bundle/

# Node/Yarn
/node_modules/
/yarn-error.log

# Assets build outputs
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets
/public/packs
/public/packs-test
/public/vite

# スクリーンショット（README 用撮影スペックの出力、リポジトリ管理不要）
/public/images/screenshots/

# Env files
.env
.env.*
!.env.example

# Kamal secrets (local only)
.kamal/secrets

# Test coverage
/coverage/

# RSpec: --only-failures / --next-failure 用のステータスファイル（ローカル専用）
/spec/examples.txt

# Editor/OS
.DS_Store
Thumbs.db
.idea/
.vscode/
