FROM ruby:3.3.2

ENV LANG=C.UTF-8
ENV TZ=Asia/Tokyo

RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
      ca-certificates curl gnupg \
      build-essential git pkg-config \
      libpq-dev postgresql-client \
      libvips-dev \
      gosu \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
      | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" \
      > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update -qq \
    && apt-get install -y --no-install-recommends nodejs \
    && corepack enable \
    && rm -rf /var/lib/apt/lists/*

# Google Chrome for system specs (headless / CDP 直接通信 by cuprite)
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends wget && \
    wget -q -O /tmp/chrome.deb https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb && \
    apt-get install -y /tmp/chrome.deb && \
    rm /tmp/chrome.deb && \
    rm -rf /var/lib/apt/lists/*

RUN gem install bundler foreman

WORKDIR /myapp
COPY . /myapp

# entrypoint をコンテナに配置
COPY bin/docker-entrypoint-dev /usr/local/bin/docker-entrypoint-dev
RUN chmod +x /usr/local/bin/docker-entrypoint-dev
ENTRYPOINT ["docker-entrypoint-dev"]
