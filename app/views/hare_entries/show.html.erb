<main class="max-w-3xl mx-auto p-4 md:p-8">
  <%# 戻るリンク %>
  <div class="mb-6">
    <%= link_to "← 一覧に戻る", hare_entries_path, class: "text-gray-600 hover:text-gray-800 font-medium" %>
  </div>

  <%# メインカード %>
  <div class="bg-white rounded-2xl shadow-sm p-5 md:p-8">
    <%# ヘッダー情報 %>
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 mb-6 pb-4 border-b border-gray-100">
      <div class="flex items-center gap-3">
        <%= app_icon("sparkles", css_class: "w-8 h-8 text-yellow-400") %>
        <p class="text-lg font-medium text-gray-700">
          <%= @hare_entry.occurred_on.strftime('%Y年%-m月%-d日') %>
        </p>
      </div>
      <% if @hare_entry.public_post? %>
        <span class="px-4 py-2 bg-orange-100 text-orange-700 rounded-full text-sm font-semibold">公開</span>
      <% else %>
        <span class="px-4 py-2 bg-gray-100 text-gray-600 rounded-full text-sm font-semibold">非公開</span>
      <% end %>
    </div>

    <%# 本文 %>
    <div class="mb-8">
      <p class="whitespace-pre-wrap text-lg leading-relaxed text-gray-800"><%= @hare_entry.body %></p>
    </div>

    <%# 写真表示 %>
    <% if @hare_entry.photo.attached? %>
      <div class="mb-8">
        <%= image_tag cloudinary_photo_url(@hare_entry.photo, resize_to_limit: [600, 600]), class: "w-full max-w-2xl rounded-xl border-2 border-gray-200 shadow-md" %>
      </div>
    <% end %>

    <%# アクションボタン %>
    <div class="flex flex-wrap gap-3 pt-6 border-t border-gray-100">
      <%= link_to "編集", edit_hare_entry_path(@hare_entry), class: "bg-gradient-to-r from-orange-400 to-orange-300 text-white px-6 py-2.5 rounded-full font-semibold hover:from-orange-500 hover:to-orange-400 transition-colors shadow-sm" %>
      <%= button_to "削除",
        hare_entry_path(@hare_entry),
        method: :delete,
        data: { turbo_confirm: "この記録を削除しますか？" },
        class: "bg-red-500 text-white px-6 py-2.5 rounded-full font-semibold hover:bg-red-600 transition-colors shadow-sm"
        %>
      <% if @hare_entry.public_post? && @hare_entry.share_token.present? %>
        <div data-controller="clipboard"
             data-clipboard-text-value="<%= share_hare_entry_url(@hare_entry.share_token) %>">
          <button data-action="click->clipboard#copy"
                  data-clipboard-target="button"
                  class="px-6 py-2.5 bg-blue-100 text-blue-700 rounded-full font-semibold hover:bg-blue-200 transition-colors">
            <%= app_icon("link", css_class: "w-4 h-4 inline-block") %> 共有URLをコピー
          </button>
          <span data-clipboard-target="feedback"
                class="hidden ml-2 text-sm text-green-600 font-medium">コピーしました！</span>
        </div>
        <%= link_to "𝕏 でシェア",
          "https://twitter.com/intent/tweet?" + { text: "#{@hare_entry.occurred_on.strftime('%Y年%-m月%-d日')}のハレ記録✨ #ケハレ帖", url: share_hare_entry_url(@hare_entry.share_token) }.to_query,
          target: "_blank",
          rel: "noopener noreferrer",
          class: "px-6 py-2.5 bg-black text-white rounded-full font-semibold hover:bg-gray-800 transition-colors" %>
      <% end %>
      <%= link_to "一覧に戻る", hare_entries_path, class: "px-6 py-2.5 text-gray-600 hover:text-gray-800 font-semibold" %>
    </div>
  </div>
</main>
