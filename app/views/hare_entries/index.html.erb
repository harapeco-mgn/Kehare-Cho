<main class="max-w-5xl mx-auto p-4 md:p-8 font-zen">
  <%# ページタイトル %>
  <h1 class="text-2xl md:text-3xl font-bold text-sumi mb-6 tracking-wide">あなたのハレ一覧</h1>

  <%# 今月のポイントとレベル表示 %>
  <div class="card bg-washi shadow-sm border border-washi-border mb-8">
    <div class="card-body">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-xs text-kincha font-bold uppercase tracking-widest mb-2">● MONTHLY PROGRESS</p>
          <div class="flex items-center gap-4 md:gap-8">
            <div>
              <p class="text-sm text-kogecha mb-1">今月のがんばり</p>
              <p class="text-2xl md:text-3xl font-bold text-kincha">
                <%= @monthly_points || 0 %><span class="text-lg text-kogecha">pt</span>
              </p>
            </div>
            <div class="h-12 w-px bg-washi-border"></div>
            <div>
              <p class="text-sm text-kogecha mb-1">ハレ度</p>
              <p class="text-2xl md:text-3xl font-bold text-sumi">Lv.<%= @level || 0 %></p>
            </div>
          </div>
        </div>
        <div class="mt-3 sm:mt-0">
          <%= app_icon("flower-2", css_class: "w-10 h-10 md:w-14 md:h-14 text-pink-300") %>
        </div>
      </div>
    </div>
  </div>

  <% if @hare_entries.any? %>
    <%# ハレ投稿カード一覧 %>
    <div class="space-y-4">
      <% @hare_entries.each do |entry| %>
        <%= link_to hare_entry_path(entry), class: "block group" do %>
          <div class="bg-washi rounded-2xl shadow-sm border border-washi-border hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 overflow-hidden">
            <%# 左側のアクセントライン %>
            <div class="flex">
              <div class="w-1 bg-gradient-to-b from-kincha to-kincha-light rounded-l-2xl flex-shrink-0"></div>
              <div class="flex-1 p-5">
                <div class="flex items-start justify-between mb-3">
                  <p class="text-sm text-kogecha">
                    <%= app_icon("sparkles", css_class: "w-3.5 h-3.5 inline-block text-kincha mr-1") %>
                    <%= entry.occurred_on.strftime('%Y年%-m月%-d日') %>
                  </p>
                  <% if entry.public_post? %>
                    <span class="inline-flex items-center px-3 py-0.5 rounded-full text-xs font-bold bg-kincha-bg text-kincha border border-kincha-border">公開</span>
                  <% else %>
                    <span class="inline-flex items-center px-3 py-0.5 rounded-full text-xs font-bold bg-[#F2F0EC] text-kogecha border border-[#E0D8CC]">非公開</span>
                  <% end %>
                </div>
                <% if entry.photo.attached? %>
                  <div class="mb-3">
                    <%= image_tag cloudinary_photo_url(entry.photo, resize_to_limit: [200, 200]), class: "rounded-xl border border-washi-border shadow-sm" %>
                  </div>
                <% end %>
                <p class="text-sumi whitespace-pre-wrap leading-relaxed group-hover:text-sumi-dark transition-colors"><%= entry.body %></p>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
    <%# ページネーション %>
    <div class="mt-8 flex justify-center">
      <%= paginate @hare_entries %>
    </div>
  <% else %>
    <%# 空状態 %>
    <div class="bg-washi rounded-3xl shadow-sm border-2 border-dashed border-washi-border text-center py-20 px-8">
      <div class="flex justify-center mb-4">
        <%= app_icon("sparkles", css_class: "w-16 h-16 text-[#F5C49A]") %>
      </div>
      <p class="text-kogecha text-lg mb-2 font-medium">まだハレの記録がありません</p>
      <p class="text-kogecha-light text-sm mb-8">最初の「小さなハレ」を見つけましょう</p>
      <%= link_to new_hare_entry_path,
          class: "btn bg-gradient-to-r from-kincha to-kincha-light text-white border-0 shadow-md hover:shadow-lg hover:-translate-y-0.5 transition-all rounded-full px-8" do %>
        <%= app_icon("plus", css_class: "w-4 h-4 mr-1") %> 記録する
      <% end %>
    </div>
  <% end %>

  <%# FABボタン（モバイル） %>
  <div class="fixed bottom-6 right-6 md:hidden z-50">
    <%= link_to new_hare_entry_path,
        class: "w-14 h-14 bg-kincha text-white rounded-full shadow-lg flex items-center justify-center hover:bg-[#B06A35] hover:scale-110 transition-all" do %>
      <%= app_icon("plus", css_class: "w-6 h-6") %>
    <% end %>
  </div>
</main>
