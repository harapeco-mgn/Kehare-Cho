<main class="max-w-3xl mx-auto px-4 py-8 font-zen">
  <%# ヘッダー %>
  <div class="mb-6">
    <h1 class="text-2xl md:text-3xl font-bold text-sumi mb-1 tracking-wide">みんなのハレ</h1>
    <p class="text-kogecha text-sm">他のユーザーのハレ投稿を見てみましょう</p>
  </div>

  <%# 投稿一覧 %>
  <% if @hare_entries.any? %>
    <div class="space-y-4">
      <% @hare_entries.each do |entry| %>
        <div class="bg-washi rounded-2xl shadow-sm border border-washi-border hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 overflow-hidden">
          <div class="flex">
            <%# 左側アクセントライン（index と同じオレンジ系） %>
            <div class="w-1 bg-gradient-to-b from-kincha to-kincha-light flex-shrink-0"></div>
            <div class="flex-1 p-5">
              <%# ユーザー情報 %>
              <div class="flex items-center mb-4">
                <div class="avatar">
                  <div class="w-10 h-10 rounded-full border-2 border-washi-border overflow-hidden">
                    <%= image_tag level_image_url(entry.user.level), alt: entry.user.display_name, class: "w-full h-full object-cover" %>
                  </div>
                </div>
                <div class="ml-3">
                  <p class="font-bold text-sumi text-sm"><%= entry.user.display_name %></p>
                  <p class="text-xs text-kogecha">
                    <%= app_icon("sparkles", css_class: "w-3 h-3 inline-block text-kincha mr-0.5") %>
                    <%= entry.occurred_on.strftime('%Y年%-m月%-d日') %>
                  </p>
                </div>
              </div>

              <%# 写真 %>
              <% if entry.photo.attached? %>
                <div class="mb-3">
                  <%= image_tag cloudinary_photo_url(entry.photo, resize_to_limit: [600, 600]), class: "rounded-xl max-h-96 max-w-full w-auto mx-auto border border-washi-border" %>
                </div>
              <% end %>

              <%# 投稿内容 %>
              <p class="text-sumi mb-3 break-words leading-relaxed"><%= linkify_body(entry.body) %></p>

              <%# タグ %>
              <% if entry.hare_tags.any? %>
                <div class="flex flex-wrap gap-2">
                  <% entry.hare_tags.each do |tag| %>
                    <span class="inline-flex items-center px-3 py-0.5 rounded-full text-xs font-bold bg-moegi-bg text-moegi border border-moegi-border">
                      <%= tag.label %>
                    </span>
                  <% end %>
                </div>
              <% end %>

              <%# 自分の投稿にのみ編集・削除ボタンを表示 %>
              <% if user_signed_in? && entry.user_id == current_user.id %>
                <div class="flex gap-2 mt-3 pt-3 border-t border-washi-rule">
                  <%= link_to edit_hare_entry_path(entry),
                      class: "btn btn-sm bg-gradient-to-r from-kincha to-kincha-light text-white border-0 rounded-full shadow hover:shadow-md hover:-translate-y-0.5 transition-all" do %>
                    <%= app_icon("pencil", css_class: "w-3 h-3 mr-1") %> 編集
                  <% end %>
                  <%= button_to hare_entry_path(entry),
                      method: :delete,
                      data: { turbo_confirm: "この記録を削除しますか？" },
                      class: "btn btn-sm btn-error rounded-full shadow hover:shadow-md hover:-translate-y-0.5 transition-all" do %>
                    <%= app_icon("trash-2", css_class: "w-3 h-3 mr-1") %> 削除
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%# ページネーション %>
    <div class="mt-8 flex justify-center">
      <%= paginate @hare_entries %>
    </div>
  <% else %>
    <%# 投稿がない場合 %>
    <div class="bg-washi rounded-3xl shadow-sm border-2 border-dashed border-washi-border text-center py-16">
      <p class="text-kogecha text-lg">まだ公開されている投稿がありません</p>
      <p class="text-kogecha-light text-sm mt-2">最初のハレをシェアしてみましょう</p>
    </div>
  <% end %>
</main>
