<main class="max-w-3xl mx-auto p-4 md:p-8 font-zen">
  <%# 戻るリンク %>
  <div class="mb-4">
    <%= link_to hare_entry_path(@hare_entry), class: "inline-flex items-center gap-1 text-kogecha hover:text-kincha font-medium transition-colors" do %>
      <%= app_icon("arrow-left", css_class: "w-4 h-4") %> 詳細に戻る
    <% end %>
  </div>

  <%# ページヘッダー %>
  <div class="mb-6">
    <h1 class="text-2xl md:text-3xl font-bold text-sumi mb-1 tracking-wide">ハレの記録を編集する</h1>
    <p class="text-kogecha flex items-center gap-1 text-sm">
      記録を更新しましょう
      <%= app_icon("notebook-pen", css_class: "w-4 h-4 text-kogecha") %>
    </p>
  </div>

  <%# フォームカード %>
  <div class="bg-washi rounded-3xl shadow-sm border border-washi-border p-6 md:p-8">
    <%= render 'form', hare_entry: @hare_entry, submit_label: "更新する", cancel_path: hare_entry_path(@hare_entry), hare_tags: @hare_tags %>
  </div>
</main>
