<main class="max-w-3xl mx-auto p-4 md:p-8 font-zen">
  <%# ページヘッダー %>
  <div class="mb-6">
    <h1 class="text-2xl md:text-3xl font-bold text-sumi mb-1 tracking-wide">今日のハレを記録する</h1>
    <p class="text-kogecha flex items-center gap-1 text-sm">
      今日のごはんで「ちょっと特別」だったことを記録しましょう
      <%= app_icon("sparkles", css_class: "w-4 h-4 text-kincha") %>
    </p>
  </div>

  <%# フォームカード %>
  <div class="bg-washi rounded-3xl shadow-sm border border-washi-border p-6 md:p-8">
    <%= render 'form', hare_entry: @hare_entry, hare_tags: @hare_tags, submit_label: "記録する", cancel_path: root_path %>
  </div>
</main>
