<main class="max-w-3xl mx-auto p-4 md:p-8 font-zen">
  <%# ページヘッダー %>
  <div class="mb-6">
    <h1 class="text-2xl md:text-3xl font-bold text-[#4A4036] mb-1 tracking-wide">今日のハレを記録する</h1>
    <p class="text-[#8D7B68] flex items-center gap-1 text-sm">
      今日のごはんで「ちょっと特別」だったことを記録しましょう
      <%= app_icon("sparkles", css_class: "w-4 h-4 text-[#C87941]") %>
    </p>
  </div>

  <%# フォームカード %>
  <div class="bg-[#FFFCF5] rounded-3xl shadow-sm border border-[#E8E0D0] p-6 md:p-8">
    <%= render 'form', hare_entry: @hare_entry, hare_tags: @hare_tags, submit_label: "記録する", cancel_path: root_path %>
  </div>
</main>
