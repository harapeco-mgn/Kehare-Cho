<main class="max-w-3xl mx-auto px-4 pt-6 pb-8 font-zen">
  <%# ページヘッダー %>
  <div class="text-center mb-8">
    <h1 class="text-3xl font-bold text-[#4A4036] mb-2">どうやって相談する？</h1>
    <p class="text-[#8D7B68] flex items-center justify-center gap-1">
      2種類の献立サポートから選んでください
      <%= app_icon("utensils", css_class: "w-5 h-5 text-[#8EA084]") %>
    </p>
  </div>

  <%# 選択カード %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <%# かんたん献立カード %>
    <div class="bg-[#8EA084] rounded-3xl p-6 md:p-8 shadow-lg flex flex-col min-h-[220px]">
      <div class="mb-3"><%= app_icon("clipboard-list", css_class: "w-10 h-10 text-white/80") %></div>
      <h2 class="text-white text-xl font-bold mb-2">かんたん献立</h2>
      <p class="text-white/90 text-sm leading-relaxed mb-6 flex-1">
        フォームで条件（ジャンル・気分・時間）を選ぶと、おすすめの献立をすぐに提案します。
      </p>
      <div class="mt-auto flex justify-end">
        <%= link_to "選ぶ", new_meal_search_path,
              class: "bg-white text-[#5C7A60] px-6 py-2 rounded-full font-semibold text-sm hover:bg-[#F5F0E8] transition-colors shadow-md" %>
      </div>
    </div>

    <%# AI献立相談カード %>
    <div class="bg-gradient-to-br from-[#C87941] to-[#A8602F] rounded-3xl p-6 md:p-8 shadow-lg flex flex-col min-h-[220px]">
      <div class="mb-3"><%= app_icon("bot", css_class: "w-10 h-10 text-white/80") %></div>
      <h2 class="text-white text-xl font-bold mb-2">AI献立相談</h2>
      <p class="text-white/90 text-sm leading-relaxed mb-6 flex-1">
        AIと会話しながらじっくり相談。料理のアドバイスや食材の使い方も聞けます。
      </p>
      <div class="mt-auto flex justify-end">
        <% if user_signed_in? %>
          <%= link_to "相談する", new_chat_path,
                class: "bg-white text-[#A8602F] px-6 py-2 rounded-full font-semibold text-sm hover:bg-[#FFF5E9] transition-colors shadow-md" %>
        <% else %>
          <%= link_to "ログインして使う", new_user_session_path,
                class: "bg-white text-[#A8602F] px-6 py-2 rounded-full font-semibold text-sm hover:bg-[#FFF5E9] transition-colors shadow-md" %>
        <% end %>
      </div>
    </div>
  </div>

  <%# 戻るリンク %>
  <div class="text-center mt-8">
    <%= link_to "ホームに戻る", root_path, class: "text-[#8D7B68] hover:text-[#C87941] text-sm transition-colors" %>
  </div>
</main>
