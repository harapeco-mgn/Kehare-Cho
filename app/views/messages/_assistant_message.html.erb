<div id="<%= dom_id(message) %>" class="flex items-start gap-2">
  <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#C87941] to-[#E8A87C] flex items-center justify-center flex-shrink-0 mt-1">
    <%= app_icon("bot", css_class: "w-4 h-4 text-white") %>
  </div>
  <div class="max-w-xs md:max-w-sm">
    <div class="bg-[#F5EDE0] rounded-2xl rounded-bl-sm px-4 py-3 border border-[#E8D8C0]">
      <p class="text-sm text-[#4A4036] whitespace-pre-wrap"><%= message.content %></p>
      <p class="text-xs text-[#8D7B68] mt-1"><%= message.created_at.strftime("%H:%M") %></p>
    </div>
    <% if chat.meal_consultation? %>
      <% dish_names = message.extract_dish_names %>
      <% if dish_names.any? %>
        <div class="mt-2 flex flex-col gap-1">
          <% dish_names.each do |dish_name| %>
            <%= link_to new_hare_entry_path(body: dish_name),
                        class: "inline-flex items-center gap-1 text-xs text-[#C87941] hover:text-[#A8602F] border border-[#E8A87C] rounded-xl px-3 py-1.5 hover:bg-[#FFF5E9] transition-colors" do %>
              <%= app_icon("pen-line", css_class: "w-3 h-3") %> <%= dish_name %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
