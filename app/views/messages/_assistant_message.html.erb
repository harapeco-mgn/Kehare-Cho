<div id="<%= dom_id(message) %>" class="flex items-start gap-2">
  <div class="w-8 h-8 rounded-full bg-gradient-to-br from-kincha to-kincha-light flex items-center justify-center flex-shrink-0 mt-1">
    <%= app_icon("bot", css_class: "w-4 h-4 text-white") %>
  </div>
  <div class="max-w-xs md:max-w-sm">
    <div class="bg-washi-gold rounded-2xl rounded-bl-sm px-4 py-3 border border-washi-tan">
      <p class="text-sm text-sumi whitespace-pre-wrap"><%= message.content %></p>
      <p class="text-xs text-kogecha mt-1"><%= message.created_at.strftime("%H:%M") %></p>
    </div>
    <% if chat.meal_consultation? %>
      <% dish_names = message.extract_dish_names %>
      <% if dish_names.any? %>
        <div class="mt-2 flex flex-col gap-1">
          <% dish_names.each do |dish_name| %>
            <%= link_to new_hare_entry_path(body: dish_name),
                        class: "inline-flex items-center gap-1 text-xs text-kincha hover:text-kincha-brown border border-kincha-light rounded-xl px-3 py-1.5 hover:bg-washi-warm transition-colors" do %>
              <%= app_icon("pen-line", css_class: "w-3 h-3") %> <%= dish_name %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
