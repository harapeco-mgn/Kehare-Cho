<main class="max-w-3xl mx-auto px-4 pt-6 pb-8 font-zen">
  <%# 自動リダイレクト処理 %>
  <div data-controller="maps-redirect" data-maps-redirect-url-value="<%= @maps_url %>">
    <%# ページヘッダー %>
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-3xl font-bold text-sumi mb-2">かんたん献立</h1>
        <p class="text-kogecha flex items-center gap-1">
          今日のごはん、何にしますか？
          <%= app_icon("utensils", css_class: "w-4 h-4 text-moegi") %>
        </p>
      </div>
      <%= link_to "ホーム", home_path, class: "text-kogecha hover:text-kincha font-medium transition-colors" %>
    </div>

    <%# メッセージカード %>
    <div class="bg-washi rounded-3xl border border-washi-border shadow-sm p-8 text-center">
      <div class="flex justify-center mb-2">
        <%= app_icon("map", css_class: "w-8 h-8 text-kincha") %>
      </div>
      <h2 class="text-xl font-bold text-sumi mb-2">近くのお店を探しています...</h2>
      <p class="text-kogecha mb-6">
        <span class="font-semibold text-kincha"><%= @genre_label %></span> のお店を Google マップで検索します
      </p>

      <%# ローディングアニメーション %>
      <div class="flex justify-center mb-8">
        <span class="loading loading-dots loading-lg text-kincha"></span>
      </div>

      <%# 手動リンク（フォールバック） %>
      <p class="text-sm text-kogecha">
        自動で移動しない場合は
        <%= link_to "こちら", @maps_url, class: "text-kincha hover:text-kincha-brown underline font-medium" %>
        をクリックしてください
      </p>
    </div>
  </div>
</main>
