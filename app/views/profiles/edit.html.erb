<div class="max-w-2xl mx-auto px-4 pt-6 pb-8 font-zen">
  <h1 class="text-2xl font-bold mb-6 text-sumi">プロフィール編集</h1>

  <%= form_with model: @user, url: profile_path, method: :patch do |f| %>
    <div class="bg-washi rounded-3xl border border-washi-border shadow-sm p-6">

      <% if @user.errors.any? %>
        <div class="bg-washi-warm border-l-4 border-kincha p-4 rounded-2xl mb-6">
          <div class="flex items-start">
            <%= app_icon("alert-circle", css_class: "flex-shrink-0 h-5 w-5 text-kincha mr-2 mt-0.5") %>
            <div>
              <h3 class="font-bold text-sumi-warm">入力内容にエラーがあります</h3>
              <ul class="list-disc list-inside mt-2 text-sumi-red text-sm">
                <% @user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      <% end %>

      <div class="mb-6">
        <label class="block text-sm font-bold text-sumi mb-1">ニックネーム</label>
        <%= f.text_field :nickname,
              class: "input w-full bg-white text-sumi border-washi-sand focus:border-kincha focus:ring-2 focus:ring-kincha/20 rounded-xl",
              placeholder: "20文字以内で入力してください",
              maxlength: 20 %>
        <p class="text-xs text-kogecha mt-1">未設定の場合はメールアドレスの @ 前が表示されます</p>
      </div>

      <div class="h-px bg-washi-border my-6"></div>

      <div class="bg-washi-warm p-4 rounded-2xl border border-washi-tan">
        <h3 class="font-bold mb-2 text-sumi">メールアドレス・パスワードの変更</h3>
        <p class="text-sm text-kogecha mb-3">
          セキュリティ上の理由により、メールアドレスとパスワードの変更は専用画面で行います。
        </p>
        <%= link_to "変更する", edit_user_registration_path,
              class: "px-4 py-2 border-2 border-kincha text-kincha rounded-xl hover:bg-washi-warm transition-colors font-semibold text-sm" %>
      </div>

      <div class="flex justify-end items-center gap-4 mt-8 pt-6 border-t border-washi-border">
        <%= link_to "キャンセル", profile_path,
              class: "px-6 py-3 text-kogecha hover:text-sumi font-semibold transition-colors" %>
        <%= f.submit "更新",
              class: "bg-gradient-to-r from-kincha to-kincha-light text-white px-8 py-3 rounded-full font-semibold hover:opacity-90 transition-opacity shadow-md cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>
