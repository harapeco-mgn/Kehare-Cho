<main class="max-w-4xl mx-auto px-4 pt-6 pb-8 font-zen">
  <%# ページヘッダー %>
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <%= app_icon("user", css_class: "w-10 h-10 text-[#8D7B68]") %>
      <h1 class="text-2xl md:text-3xl font-bold text-[#4A4036]">プロフィール</h1>
    </div>
    <p class="text-[#8D7B68]">あなたの情報と記録</p>
  </div>

  <%# プロフィールカード %>
  <div class="bg-[#FFFCF5] rounded-3xl border border-[#E8E0D0] shadow-sm p-5 md:p-8">
    <h2 class="text-xl font-bold text-[#4A4036] mb-6">基本情報</h2>

    <div class="space-y-6">
      <%# 表示名 %>
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 py-4 border-b border-[#E8E0D0]">
        <span class="text-sm font-semibold text-[#8D7B68]">表示名</span>
        <span class="text-lg font-medium text-[#4A4036]"><%= @user.display_name %></span>
      </div>

      <%# メールアドレス %>
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 py-4 border-b border-[#E8E0D0]">
        <span class="text-sm font-semibold text-[#8D7B68]">メールアドレス</span>
        <span class="text-lg text-[#4A4036] break-all"><%= @user.email %></span>
      </div>

      <%# 現在のレベル %>
      <div class="py-6 border-b border-[#E8E0D0]">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm font-semibold text-[#8D7B68]">ハレ度</span>
          <div class="text-right">
            <div class="text-2xl font-bold text-[#C87941] mb-1">Lv.<%= @user.level %></div>
            <div class="text-sm text-[#8D7B68]"><%= level_name(@user.level) %></div>
          </div>
        </div>
        <%# レベルイラスト %>
        <div class="flex justify-center mt-4">
          <%= image_tag level_image_url(@user.level),
                        alt: level_name(@user.level),
                        class: "w-28 h-28 md:w-40 md:h-40 rounded-full shadow-lg object-cover border-4 border-[#E8E0D0]" %>
        </div>
      </div>

      <%# 累計ポイント %>
      <div class="flex items-center justify-between py-4 border-b border-[#E8E0D0]">
        <span class="text-sm font-semibold text-[#8D7B68]">累計ポイント</span>
        <div class="flex items-center gap-2">
          <%= app_icon("sparkles", css_class: "w-5 h-5 text-[#C87941]") %>
          <span class="text-lg font-semibold text-[#4A4036]"><%= @total_points %> pt</span>
        </div>
      </div>

      <%# 総ハレ投稿数 %>
      <div class="flex items-center justify-between py-4 border-b border-[#E8E0D0]">
        <span class="text-sm font-semibold text-[#8D7B68]">総ハレ投稿数</span>
        <div class="flex items-center gap-2">
          <%= app_icon("flower-2", css_class: "w-5 h-5 text-[#C87941]") %>
          <span class="text-lg font-semibold text-[#4A4036]"><%= @total_hare_entries_count %> 件</span>
        </div>
      </div>

      <%# 登録日 %>
      <div class="flex items-center justify-between py-4">
        <span class="text-sm font-semibold text-[#8D7B68]">登録日</span>
        <span class="text-lg text-[#4A4036]"><%= l(@user.created_at.to_date, format: :long) %></span>
      </div>
    </div>

    <%# 編集ボタン %>
    <div class="mt-8 pt-6 border-t border-[#E8E0D0]">
      <%= link_to "編集", edit_profile_path,
            class: "bg-gradient-to-r from-[#C87941] to-[#E8A87C] text-white px-8 py-3 rounded-full font-semibold hover:opacity-90 transition-opacity shadow-md inline-block" %>
    </div>
  </div>
</main>
