<main class="max-w-4xl mx-auto px-4 pt-6 pb-8 font-zen">
  <%# ページヘッダー %>
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <%= app_icon("user", css_class: "w-10 h-10 text-kogecha") %>
      <h1 class="text-2xl md:text-3xl font-bold text-sumi">プロフィール</h1>
    </div>
    <p class="text-kogecha">あなたの情報と記録</p>
  </div>

  <%# プロフィールカード %>
  <div class="bg-washi rounded-3xl border border-washi-border shadow-sm p-5 md:p-8">
    <h2 class="text-xl font-bold text-sumi mb-6">基本情報</h2>

    <div class="space-y-6">
      <%# 表示名 %>
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 py-4 border-b border-washi-border">
        <span class="text-sm font-semibold text-kogecha">表示名</span>
        <span class="text-lg font-medium text-sumi"><%= @user.display_name %></span>
      </div>

      <%# メールアドレス %>
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 py-4 border-b border-washi-border">
        <span class="text-sm font-semibold text-kogecha">メールアドレス</span>
        <span class="text-lg text-sumi break-all"><%= @user.email %></span>
      </div>

      <%# 現在のレベル %>
      <div class="py-6 border-b border-washi-border">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm font-semibold text-kogecha">ハレ度</span>
          <div class="text-right">
            <div class="text-2xl font-bold text-kincha mb-1">Lv.<%= @user.level %></div>
            <div class="text-sm text-kogecha"><%= level_name(@user.level) %></div>
          </div>
        </div>
        <%# レベルイラスト %>
        <div class="flex justify-center mt-4">
          <%= image_tag level_image_url(@user.level),
                        alt: level_name(@user.level),
                        class: "w-28 h-28 md:w-40 md:h-40 rounded-full shadow-lg object-cover border-4 border-washi-border" %>
        </div>
      </div>

      <%# 累計ポイント %>
      <div class="flex items-center justify-between py-4 border-b border-washi-border">
        <span class="text-sm font-semibold text-kogecha">累計ポイント</span>
        <div class="flex items-center gap-2">
          <%= app_icon("sparkles", css_class: "w-5 h-5 text-kincha") %>
          <span class="text-lg font-semibold text-sumi"><%= @total_points %> pt</span>
        </div>
      </div>

      <%# 総ハレ投稿数 %>
      <div class="flex items-center justify-between py-4 border-b border-washi-border">
        <span class="text-sm font-semibold text-kogecha">総ハレ投稿数</span>
        <div class="flex items-center gap-2">
          <%= app_icon("flower-2", css_class: "w-5 h-5 text-kincha") %>
          <span class="text-lg font-semibold text-sumi"><%= @total_hare_entries_count %> 件</span>
        </div>
      </div>

      <%# 登録日 %>
      <div class="flex items-center justify-between py-4">
        <span class="text-sm font-semibold text-kogecha">登録日</span>
        <span class="text-lg text-sumi"><%= l(@user.created_at.to_date, format: :long) %></span>
      </div>
    </div>

    <%# 編集ボタン %>
    <div class="mt-8 pt-6 border-t border-washi-border">
      <%= link_to "編集", edit_profile_path,
            class: "bg-gradient-to-r from-kincha to-kincha-light text-white px-8 py-3 rounded-full font-semibold hover:opacity-90 transition-opacity shadow-md inline-block" %>
    </div>
  </div>
</main>
