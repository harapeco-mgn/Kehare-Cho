<div class="min-h-[60vh] flex items-center justify-center py-12 px-4 font-zen">
  <div class="w-full max-w-md">
    <div class="bg-[#FFFCF5] rounded-3xl border border-[#E8E0D0] shadow-md p-8">
      <h2 class="text-xl font-bold text-[#4A4036] mb-6"><%= t('.title', resource: devise_i18n_fix_model_name_case(resource.model_name.human, i18n_key: 'registrations.edit.title')) %></h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="mb-4">
          <%= f.label :email, class: "block text-sm font-semibold text-[#4A4036] mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "input w-full bg-white text-[#4A4036] border-[#D6CCB8] focus:border-[#C87941] focus:ring-2 focus:ring-[#C87941]/20 rounded-xl" %>
        </div>

        <div class="mb-4">
          <%= f.label :nickname, class: "block text-sm font-semibold text-[#4A4036] mb-1" %>
          <%= f.text_field :nickname, autocomplete: "nickname",
                class: "input w-full bg-white text-[#4A4036] border-[#D6CCB8] focus:border-[#C87941] focus:ring-2 focus:ring-[#C87941]/20 rounded-xl" %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <div class="bg-[#FFF5E9] border-l-4 border-[#C87941] p-3 mb-4 text-sm text-[#6B3A2A] rounded-r-xl">
            <%= t('.currently_waiting_confirmation_for_email', email: resource.unconfirmed_email) %>
          </div>
        <% end %>

        <div class="mb-4">
          <%= f.label :password, class: "block text-sm font-semibold text-[#4A4036] mb-1" %>
          <span class="text-xs text-[#8D7B68] mb-1 block"><%= t('.leave_blank_if_you_don_t_want_to_change_it') %></span>
          <%= f.password_field :password, autocomplete: "new-password",
                class: "input w-full bg-white text-[#4A4036] border-[#D6CCB8] focus:border-[#C87941] focus:ring-2 focus:ring-[#C87941]/20 rounded-xl" %>
          <% if @minimum_password_length %>
            <span class="text-xs text-[#8D7B68] mt-1 block"><%= t('devise.shared.minimum_password_length', count: @minimum_password_length) %></span>
          <% end %>
        </div>

        <div class="mb-4">
          <%= f.label :password_confirmation, class: "block text-sm font-semibold text-[#4A4036] mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
                class: "input w-full bg-white text-[#4A4036] border-[#D6CCB8] focus:border-[#C87941] focus:ring-2 focus:ring-[#C87941]/20 rounded-xl" %>
        </div>

        <div class="mb-6">
          <%= f.label :current_password, class: "block text-sm font-semibold text-[#4A4036] mb-1" %>
          <span class="text-xs text-[#8D7B68] mb-1 block"><%= t('.we_need_your_current_password_to_confirm_your_changes') %></span>
          <%= f.password_field :current_password, autocomplete: "current-password",
                class: "input w-full bg-white text-[#4A4036] border-[#D6CCB8] focus:border-[#C87941] focus:ring-2 focus:ring-[#C87941]/20 rounded-xl" %>
        </div>

        <div class="mt-6">
          <%= f.submit t('.update'),
                class: "btn w-full bg-gradient-to-r from-[#C87941] to-[#E8A87C] text-white border-0 rounded-full font-bold text-base hover:opacity-90 transition-opacity shadow-sm cursor-pointer" %>
        </div>
      <% end %>

      <div class="h-px bg-[#E8E0D0] my-6"></div>

      <div class="bg-[#FDF3F0] border border-[#C87941]/30 rounded-2xl p-4">
        <h3 class="font-bold text-[#6B3A2A] mb-2"><%= t('.cancel_my_account') %></h3>
        <p class="text-sm text-[#8B4A3A] mb-3"><%= t('.unhappy') %></p>
        <%= button_to t('.cancel_my_account'), registration_path(resource_name),
              data: { confirm: t('.are_you_sure'), turbo_confirm: t('.are_you_sure') },
              method: :delete,
              class: "btn btn-sm bg-red-600 hover:bg-red-700 text-white border-0 rounded-xl" %>
      </div>

      <div class="mt-6 text-center">
        <%= link_to t('devise.shared.links.back'), :back, class: "text-[#8D7B68] hover:text-[#C87941] underline text-sm transition-colors" %>
      </div>
    </div>
  </div>
</div>
