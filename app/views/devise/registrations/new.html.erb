<% sign_up_label = t('.sign_up') %>
<%= render layout: "devise/shared/auth_wrapper" do %>
  <h2 class="text-xl font-bold text-sumi mb-6"><%= sign_up_label %></h2>

  <%# Google で新規登録ボタン %>
  <%= button_to user_google_oauth2_omniauth_authorize_path,
        method: :post,
        data: { turbo: false },
        class: "btn w-full bg-white text-sumi border border-washi-sand rounded-full font-bold text-base hover:bg-washi-cream transition-colors shadow-sm cursor-pointer flex items-center justify-center gap-2 mb-4" do %>
    <svg class="w-5 h-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
      <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
      <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
      <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
    </svg>
    Google で登録
  <% end %>

  <%# メール/パスワード フォームとの区切り %>
  <div class="flex items-center gap-3 mb-4">
    <div class="flex-1 h-px bg-washi-border"></div>
    <span class="text-xs text-kogecha">または</span>
    <div class="flex-1 h-px bg-washi-border"></div>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="mb-4">
      <%= f.label :email, class: "block text-sm font-semibold text-sumi mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "input w-full bg-white text-sumi border-washi-sand focus:border-kincha focus:ring-2 focus:ring-kincha/20 rounded-xl" %>
    </div>

    <div class="mb-4">
      <%= f.label :nickname, class: "block text-sm font-semibold text-sumi mb-1" %>
      <%= f.text_field :nickname, autocomplete: "nickname",
            class: "input w-full bg-white text-sumi border-washi-sand focus:border-kincha focus:ring-2 focus:ring-kincha/20 rounded-xl" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, class: "block text-sm font-semibold text-sumi mb-1" %>
      <% if @minimum_password_length %>
        <span class="text-xs text-kogecha mb-1 block"><%= t('devise.shared.minimum_password_length', count: @minimum_password_length) %></span>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password",
            class: "input w-full bg-white text-sumi border-washi-sand focus:border-kincha focus:ring-2 focus:ring-kincha/20 rounded-xl" %>
    </div>

    <div class="mb-4">
      <%= f.label :password_confirmation, class: "block text-sm font-semibold text-sumi mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "input w-full bg-white text-sumi border-washi-sand focus:border-kincha focus:ring-2 focus:ring-kincha/20 rounded-xl" %>
    </div>

    <div class="mt-6">
      <%= f.submit sign_up_label,
            class: "btn w-full bg-gradient-to-r from-kincha to-kincha-light text-white border-0 rounded-full font-bold text-base hover:opacity-90 transition-opacity shadow-sm cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 pt-5 border-t border-washi-border">
    <%= render "devise/shared/links" %>
  </div>
<% end %>
