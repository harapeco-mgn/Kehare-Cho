<% content_for :hide_header, true %>
<% content_for :hide_footer, true %>

<div class="min-h-screen bg-[#F5F0E8] flex items-center justify-center py-12 px-4 font-zen">
  <div class="w-full max-w-md">
    <%# アプリロゴ %>
    <div class="text-center mb-8">
      <%= app_icon("flower-2", css_class: "w-10 h-10 text-[#C87941] inline-block mb-2") %>
      <h1 class="text-2xl font-bold text-[#4A4036] tracking-widest">keharecho</h1>
      <p class="text-sm text-[#8D7B68] mt-1">日常に小さなハレを</p>
    </div>

    <div class="bg-[#FFFCF5] rounded-3xl border border-[#E8E0D0] shadow-md p-8">
      <h2 class="text-xl font-bold text-[#4A4036] mb-6"><%= t('.sign_in') %></h2>

      <%# Google でログインボタン %>
      <%= button_to user_google_oauth2_omniauth_authorize_path,
            method: :post,
            class: "btn w-full bg-white text-[#4A4036] border border-[#D6CCB8] rounded-full font-bold text-base hover:bg-[#F5F0E8] transition-colors shadow-sm cursor-pointer flex items-center justify-center gap-2 mb-4" do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Google でログイン
      <% end %>

      <%# メール/パスワード フォームとの区切り %>
      <div class="flex items-center gap-3 mb-4">
        <div class="flex-1 h-px bg-[#E8E0D0]"></div>
        <span class="text-xs text-[#8D7B68]">または</span>
        <div class="flex-1 h-px bg-[#E8E0D0]"></div>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="mb-4">
          <%= f.label :email, class: "block text-sm font-semibold text-[#4A4036] mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "input w-full bg-white text-[#4A4036] border-[#D6CCB8] focus:border-[#C87941] focus:ring-2 focus:ring-[#C87941]/20 rounded-xl" %>
        </div>

        <div class="mb-4">
          <%= f.label :password, class: "block text-sm font-semibold text-[#4A4036] mb-1" %>
          <%= f.password_field :password, autocomplete: "current-password",
                class: "input w-full bg-white text-[#4A4036] border-[#D6CCB8] focus:border-[#C87941] focus:ring-2 focus:ring-[#C87941]/20 rounded-xl" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="mb-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <%= f.check_box :remember_me, class: "checkbox checkbox-sm border-[#D6CCB8] checked:bg-[#C87941] rounded" %>
              <span class="text-sm text-[#8D7B68]"><%= f.label :remember_me %></span>
            </label>
          </div>
        <% end %>

        <div class="mt-6">
          <%= f.submit t('.sign_in'),
                class: "btn w-full bg-gradient-to-r from-[#C87941] to-[#E8A87C] text-white border-0 rounded-full font-bold text-base hover:opacity-90 transition-opacity shadow-sm cursor-pointer" %>
        </div>
      <% end %>

      <div class="mt-6 pt-5 border-t border-[#E8E0D0]">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
