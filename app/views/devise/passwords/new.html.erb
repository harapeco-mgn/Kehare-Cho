<% forgot_pwd_title = t('.forgot_your_password') %>
<% send_instructions_label = t('.send_me_reset_password_instructions') %>
<%= render layout: "devise/shared/auth_wrapper" do %>
  <h2 class="text-xl font-bold text-sumi mb-6"><%= forgot_pwd_title %></h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="mb-4">
      <%= f.label :email, class: "block text-sm font-semibold text-sumi mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "input w-full bg-white text-sumi border-washi-sand focus:border-kincha focus:ring-2 focus:ring-kincha/20 rounded-xl" %>
    </div>

    <div class="mt-6">
      <%= f.submit send_instructions_label,
            class: "btn w-full bg-gradient-to-r from-kincha to-kincha-light text-white border-0 rounded-full font-bold text-base hover:opacity-90 transition-opacity shadow-sm cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 pt-5 border-t border-washi-border">
    <%= render "devise/shared/links" %>
  </div>
<% end %>
