<!DOCTYPE html>
<html data-theme="light">
  <head>
    <meta charset="utf-8">
    <title><%= content_for(:title) || "ケハレ帖 - 今日のごはんに、小さなハレを" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%# meta description（SEO） %>
    <meta name="description" content="<%= content_for(:description) || "一人暮らしの食事に、小さなハレを足す。毎日の食事記録アプリ「ケハレ帖」" %>">

    <%# OGP（Open Graph Protocol） %>
    <meta property="og:title"       content="<%= content_for(:title) || "ケハレ帖 - 今日のごはんに、小さなハレを" %>">
    <meta property="og:description" content="<%= content_for(:description) || "一人暮らしの食事に、小さなハレを足す。毎日の食事記録アプリ「ケハレ帖」" %>">
    <meta property="og:type"        content="website">
    <meta property="og:url"         content="<%= request.original_url %>">
    <meta property="og:image"       content="<%= image_url("ogp.png") %>">
    <meta property="og:site_name"   content="ケハレ帖">
    <meta property="og:locale"      content="ja_JP">

    <%# Twitter Card %>
    <meta name="twitter:card"        content="summary_large_image">
    <meta name="twitter:title"       content="<%= content_for(:title) || "ケハレ帖 - 今日のごはんに、小さなハレを" %>">
    <meta name="twitter:description" content="<%= content_for(:description) || "一人暮らしの食事に、小さなハレを足す。毎日の食事記録アプリ「ケハレ帖」" %>">
    <meta name="twitter:image"       content="<%= image_url("ogp.png") %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="ケハレ帖">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# 和モダンフォント %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;500;700&display=swap" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#FEF7ED]">
    <% unless content_for?(:hide_header) %>
      <% if user_signed_in? %>
        <%= render 'shared/header' %>
      <% else %>
        <%= render 'shared/guest_header' %>
      <% end %>
    <% end %>

    <div class="container mx-auto px-4 py-6">
      <%= render 'shared/flash' %>
      <%= yield %>
    </div>

    <% unless content_for?(:hide_footer) %>
      <%= render 'shared/footer' %>
    <% end %>
  </body>
</html>
