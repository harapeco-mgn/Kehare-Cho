<% content_for :title, "#{@hare_entry.user.display_name}さんのハレ記録 | ケハレ帖" %>
<% content_for :og_title, "#{@hare_entry.user.display_name}さんのハレ記録" %>
<% content_for :og_description, @hare_entry.body.truncate(100) %>
<% if @hare_entry.photo.attached? %>
  <% content_for :og_image, cloudinary_photo_url(@hare_entry.photo, resize_to_limit: [1200, 630]) %>
<% end %>

<main class="max-w-3xl mx-auto p-4 md:p-8 font-zen">
  <%# ヘッダー %>
  <div class="text-center mb-8">
    <%= app_icon("flower-2", css_class: "w-8 h-8 text-kincha inline-block mb-2") %>
    <%= link_to root_path, class: "block" do %>
      <h1 class="text-2xl font-bold text-sumi">ケハレ帖</h1>
      <p class="text-sm text-kogecha mt-1">日常の食事に小さなハレを</p>
    <% end %>
  </div>

  <%# ノート風メインカード %>
  <div class="relative bg-washi rounded-3xl shadow-md border-2 border-washi-border overflow-hidden">

    <%# 罫線背景 %>
    <div class="absolute inset-0 pointer-events-none"
         style="background-image: repeating-linear-gradient(transparent, transparent calc(2.5rem - 1px), #EBE5D9 2.5rem);"></div>

    <%# 穴パンチ装飾（左側） %>
    <div class="absolute top-0 left-5 flex flex-col gap-10 pt-8 h-full pointer-events-none z-20">
      <div class="w-4 h-4 rounded-full bg-[#F9F6EE] border-2 border-washi-border shadow-inner"></div>
      <div class="w-4 h-4 rounded-full bg-[#F9F6EE] border-2 border-washi-border shadow-inner"></div>
      <div class="w-4 h-4 rounded-full bg-[#F9F6EE] border-2 border-washi-border shadow-inner"></div>
      <div class="w-4 h-4 rounded-full bg-[#F9F6EE] border-2 border-washi-border shadow-inner"></div>
      <div class="w-4 h-4 rounded-full bg-[#F9F6EE] border-2 border-washi-border shadow-inner"></div>
      <div class="w-4 h-4 rounded-full bg-[#F9F6EE] border-2 border-washi-border shadow-inner"></div>
    </div>

    <%# コンテンツ本体 %>
    <div class="relative z-10 p-8 pl-14">

      <%# ヘッダー: 投稿者 + 日付 %>
      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 mb-6 pb-4 border-b border-washi-rule">
        <div class="flex items-center gap-3">
          <%= app_icon("sparkles", css_class: "w-6 h-6 text-kincha") %>
          <div>
            <p class="font-semibold text-sumi"><%= @hare_entry.user.display_name %></p>
            <p class="text-sm text-kogecha">
              <%= @hare_entry.occurred_on.strftime('%Y年%-m月%-d日') %>
            </p>
          </div>
        </div>
        <%# 公開スタンプ風バッジ %>
        <div class="flex flex-col items-center gap-1">
          <div class="w-14 h-14 rounded-full border-2 border-kincha/50 flex items-center justify-center rotate-6 bg-white/80 shadow-sm">
            <%= app_icon("sparkles", css_class: "w-6 h-6 text-kincha") %>
          </div>
          <span class="text-xs font-bold text-kincha rotate-3">公開中</span>
        </div>
      </div>

      <%# 本文 %>
      <div class="mb-8" style="line-height: 2.5rem;">
        <p class="whitespace-pre-wrap text-sumi text-lg"><%= linkify_body(@hare_entry.body) %></p>
      </div>

      <%# 写真 %>
      <% if @hare_entry.photo.attached? %>
        <div class="mb-8">
          <%= image_tag cloudinary_photo_url(@hare_entry.photo, resize_to_limit: [600, 600]),
            class: "w-full max-w-2xl rounded-2xl border-2 border-washi-border shadow-md" %>
        </div>
      <% end %>

      <%# タグ %>
      <% if @hare_entry.hare_tags.any? %>
        <div class="flex flex-wrap gap-2 mb-6">
          <% @hare_entry.hare_tags.each do |tag| %>
            <span class="inline-flex items-center px-3 py-0.5 rounded-full text-xs font-bold bg-moegi-bg text-moegi border border-moegi-border">
              <%= tag.label %>
            </span>
          <% end %>
        </div>
      <% end %>

      <%# X シェアボタン %>
      <div class="pt-4 border-t border-washi-rule">
        <%= link_to "𝕏 でシェア",
          "https://twitter.com/intent/tweet?" + { text: x_share_text(@hare_entry), url: request.url }.to_query,
          target: "_blank",
          rel: "noopener noreferrer",
          class: "btn bg-sumi text-white border-0 rounded-full shadow hover:bg-sumi-dark hover:-translate-y-0.5 transition-all" %>
      </div>

    </div>
  </div>

  <%# CTA セクション %>
  <div class="mt-8 bg-washi rounded-3xl border border-washi-border shadow-sm p-6 text-center">
    <p class="text-sm text-kogecha mb-1">あなたも記録してみませんか？</p>
    <p class="text-lg font-bold text-sumi mb-5">毎日の食事に、小さなハレを</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <%= link_to "新規登録（無料）", new_user_registration_path,
        class: "btn bg-gradient-to-r from-kincha to-kincha-light text-white border-0 rounded-full shadow hover:shadow-md hover:-translate-y-0.5 transition-all" %>
      <%= link_to "ログイン", new_user_session_path,
        class: "btn btn-outline border-kincha text-kincha hover:bg-orange-50 hover:border-kincha hover:text-kincha rounded-full transition-colors" %>
    </div>
    <div class="mt-4">
      <%= link_to "みんなのハレを見る →", public_hare_entries_path,
        class: "text-sm text-kogecha hover:text-kincha underline transition-colors" %>
    </div>
  </div>

  <%# フッター %>
  <div class="text-center mt-6 text-sm text-kogecha space-y-2">
    <p>ケハレ帖 — 日常の食事に小さなハレを</p>
    <div class="flex justify-center gap-4">
      <%= link_to "使い方", how_to_use_path, class: "hover:text-kincha transition-colors" %>
      <%= link_to "プライバシーポリシー", privacy_policy_path, class: "hover:text-kincha transition-colors" %>
    </div>
  </div>
</main>
