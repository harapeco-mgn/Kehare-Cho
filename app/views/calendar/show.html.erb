<%# turbo-frame 外のナビ（直接アクセス時のみ表示、フレーム経由時は無視される） %>
<div class="max-w-2xl mx-auto px-4 pt-6 pb-2 font-zen flex items-center gap-3">
  <%= link_to "← 月へ戻る", calendar_path,
      class: "text-[#8D7B68] hover:text-[#C87941] font-medium transition-colors text-sm" %>
  <span class="text-[#D6CCB8]">|</span>
  <%= link_to "新規投稿", new_hare_entry_path,
      class: "bg-gradient-to-r from-[#C87941] to-[#E8A87C] text-white px-4 py-1.5 rounded-full font-semibold text-sm hover:opacity-90 transition-opacity shadow-sm" %>
</div>

<div class="max-w-2xl mx-auto px-4 pb-8 font-zen">
  <turbo-frame id="calendar-detail">
    <% if @hare_entries.any? %>
      <%= render "calendar/entry_detail", entry: @hare_entries.first, date: @date %>

      <%# 複数の投稿がある場合の案内 %>
      <% if @hare_entries.size > 1 %>
        <div class="mt-3 text-center">
          <p class="text-xs text-[#8D7B68]">
            この日は他に <%= @hare_entries.size - 1 %> 件の記録があります →
            <%= link_to "すべて見る", hare_entries_path, class: "text-[#C87941] font-bold hover:underline" %>
          </p>
        </div>
      <% end %>
    <% else %>
      <%= render "calendar/entry_empty", date: @date %>
    <% end %>
  </turbo-frame>
</div>
