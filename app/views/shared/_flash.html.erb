<% flash.each do |type, message| %>
  <% if type == 'notice' %>
    <div class="mx-4 mt-3 px-4 py-3 bg-[#F0F7F1] border border-moegi rounded-2xl text-[#3D5E42] text-sm flex items-center gap-2">
      <%= app_icon("circle-check", css_class: "w-4 h-4 text-moegi flex-shrink-0") %>
      <span><%= message %></span>
    </div>
  <% else %>
    <div class="mx-4 mt-3 px-4 py-3 bg-washi-warm border border-kincha/50 rounded-2xl text-sumi-warm text-sm flex items-center gap-2">
      <%= app_icon("alert-circle", css_class: "w-4 h-4 text-kincha flex-shrink-0") %>
      <span><%= message %></span>
    </div>
  <% end %>
<% end %>
