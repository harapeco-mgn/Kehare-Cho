<% nav_items = [
  { label: "ホーム",       path: home_path },
  { label: "カレンダー",   path: calendar_path },
  { label: "かんたん献立", path: new_meal_search_path },
  { label: "AI相談",       path: new_chat_path },
  { label: "振り返り",     path: reflection_path },
  { label: "みんなのハレ", path: public_hare_entries_path },
  { label: "ハレ投稿",     path: new_hare_entry_path },
  { label: "プロフィール", path: profile_path }
] %>
<header class="navbar bg-washi shadow-md">
  <%# モバイル: ハンバーガー + アプリ名 %>
  <div class="navbar-start">
    <div class="dropdown">
      <div tabindex="0" role="button" class="btn btn-ghost lg:hidden">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
        </svg>
      </div>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-washi rounded-box w-52">
        <% nav_items.each do |item| %>
          <li><%= active_link_to item[:label], item[:path], class: "text-sumi hover:text-kincha" %></li>
        <% end %>
        <li>
          <%# data-turbo="false" をフォーム要素に設定し Turbo のインターセプトを防ぐ %>
          <%= button_to "ログアウト", destroy_user_session_path, method: :delete,
                        form: { "data-turbo" => "false" },
                        class: "btn bg-kincha hover:bg-kincha-hover text-white btn-sm border-0 w-full mt-1" %>
        </li>
      </ul>
    </div>
    <%= link_to t('app_name'), root_path, class: "text-xl font-bold text-sumi" %>
  </div>

  <%# デスクトップ: 横並びメニュー %>
  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 space-x-2">
      <% nav_items.each do |item| %>
        <li><%= active_link_to item[:label], item[:path], class: "btn btn-ghost btn-sm text-sumi hover:text-kincha" %></li>
      <% end %>
    </ul>
  </div>

  <%# ログアウトボタン %>
  <%# data-turbo="false" をフォーム要素に設定し Turbo の302リダイレクト未処理を防ぐ %>
  <div id="desktop-nav" class="navbar-end hidden lg:flex">
    <%= button_to "ログアウト", destroy_user_session_path, method: :delete,
                  form: { "data-turbo" => "false" },
                  class: "btn bg-kincha hover:bg-kincha-hover text-white btn-sm border-0" %>
  </div>
</header>
