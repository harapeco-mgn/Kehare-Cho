<main class="max-w-2xl mx-auto px-4 pt-6 pb-8 font-zen">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-sumi mb-1 flex items-center gap-2">
        <%= app_icon("book-open", css_class: "w-6 h-6 text-kincha") %> 食生活レポート
      </h1>
      <p class="text-kogecha text-sm">直近30日間の記録から集計しています</p>
    </div>
    <%= link_to "ホーム", home_path, class: "text-kogecha hover:text-kincha text-sm font-medium transition-colors" %>
  </div>

  <%# 記録統計カード %>
  <div class="grid grid-cols-3 gap-3 mb-6">
    <div class="bg-washi rounded-2xl border border-washi-border shadow-sm p-4 text-center">
      <p class="text-3xl font-bold text-kincha"><%= @stats.entry_count %></p>
      <p class="text-xs text-kogecha mt-1">記録数</p>
    </div>
    <div class="bg-washi rounded-2xl border border-washi-border shadow-sm p-4 text-center">
      <p class="text-3xl font-bold text-kincha"><%= @stats.recording_rate %><span class="text-lg font-bold">%</span></p>
      <p class="text-xs text-kogecha mt-1">記録率</p>
    </div>
    <div class="bg-washi rounded-2xl border border-washi-border shadow-sm p-4 text-center">
      <p class="text-3xl font-bold text-kincha"><%= @stats.current_streak %><span class="text-lg font-bold">日</span></p>
      <p class="text-xs text-kogecha mt-1 flex items-center justify-center gap-0.5">
        <%= app_icon("flame", css_class: "w-3.5 h-3.5 text-kincha") %> 連続記録
      </p>
    </div>
  </div>

  <%# タグランキング %>
  <div class="bg-washi rounded-2xl border border-washi-border shadow-sm p-5 mb-6">
    <h2 class="text-sm font-semibold text-sumi mb-3 flex items-center gap-1">
      <%= app_icon("tag", css_class: "w-4 h-4 text-kogecha") %> よく使ったタグ TOP3
    </h2>
    <% if @stats.tag_ranking.empty? %>
      <p class="text-sm text-kogecha-light">まだタグをつけた記録がありません</p>
    <% else %>
      <% @stats.tag_ranking.each_with_index do |(label, count), i| %>
        <div class="flex items-center gap-3 mb-2 last:mb-0">
          <span class="text-xs text-kogecha-light w-4 flex-shrink-0"><%= i + 1 %>位</span>
          <span class="text-sm text-sumi flex-1">#<%= label %></span>
          <div class="flex items-center gap-2">
            <div class="bg-washi-blush rounded-full h-2" style="width: <%= [count * 8, 80].min %>px; min-width: 16px;"></div>
            <span class="text-xs text-kogecha w-8 text-right"><%= count %>回</span>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# ポイントカード %>
  <div class="grid grid-cols-2 gap-3 mb-6">
    <div class="bg-washi rounded-2xl border border-washi-border shadow-sm p-4 text-center">
      <p class="text-3xl font-bold text-kincha"><%= @stats.total_points %><span class="text-lg font-bold">pt</span></p>
      <p class="text-xs text-kogecha mt-1">累計ポイント</p>
    </div>
    <div class="bg-washi rounded-2xl border border-washi-border shadow-sm p-4 text-center">
      <p class="text-3xl font-bold text-kincha"><%= @stats.average_points %><span class="text-lg font-bold">pt</span></p>
      <p class="text-xs text-kogecha mt-1">平均/記録</p>
    </div>
  </div>

  <%# AI分析 %>
  <turbo-frame id="ai_analysis">
    <div class="bg-washi rounded-2xl border border-washi-border shadow-sm p-5">
      <h2 class="text-sm font-semibold text-sumi mb-3 flex items-center gap-1">
        <%= app_icon("bot", css_class: "w-4 h-4 text-kincha") %> AI 傾向分析
      </h2>
      <% if @stats.enough_data? %>
        <%# 分析ボタン %>
        <%= button_to analyze_reflection_path,
              method: :post,
              class: "w-full bg-gradient-to-r from-kincha to-kincha-light text-white py-3 rounded-2xl font-semibold text-sm hover:opacity-90 transition-opacity cursor-pointer inline-flex items-center justify-center gap-1.5 shadow-sm",
              data: { turbo_submits_with: "分析中..." } do %>
          <%= app_icon("sparkles", css_class: "w-4 h-4") %> 分析を生成する
        <% end %>
      <% else %>
        <%# データ不足: プログレスバー %>
        <div class="bg-washi-warm rounded-2xl p-5 border border-washi-tan">
          <p class="text-xs text-kincha font-semibold mb-3 text-center">
            あと <%= HareEntryStatsService::ENOUGH_DATA_THRESHOLD - @stats.unique_days_count %> 日分記録すると分析できます
          </p>
          <div class="w-full bg-washi-blush rounded-full h-2 mb-2">
            <div class="bg-gradient-to-r from-kincha to-kincha-light h-2 rounded-full transition-all"
                 style="width: <%= (@stats.unique_days_count * 100.0 / HareEntryStatsService::ENOUGH_DATA_THRESHOLD).round %>%"></div>
          </div>
          <p class="text-xs text-center text-kogecha">
            <%= @stats.unique_days_count %> / <%= HareEntryStatsService::ENOUGH_DATA_THRESHOLD %> 日
          </p>
        </div>
      <% end %>
    </div>
  </turbo-frame>
</main>
